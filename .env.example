# Local integration-test defaults. Copy to .env for local runs.
# CI should inject these as environment variables or secrets instead.

# Postgres used by ignored e2e tests.
CDSYNC_E2E_PG_URL=postgres://cdsync:cdsync@localhost:5433/cdsync

# BigQuery emulator used by ignored local e2e tests.
CDSYNC_E2E_BQ_HTTP=http://localhost:9050
CDSYNC_E2E_BQ_GRPC=localhost:9051
CDSYNC_E2E_BQ_PROJECT=cdsync
CDSYNC_E2E_BQ_DATASET=cdsync_e2e

# Real BigQuery used by ignored live e2e tests.
CDSYNC_REAL_BQ_PROJECT=nora-461013
CDSYNC_REAL_BQ_DATASET=cdsync_e2e_real
CDSYNC_REAL_BQ_LOCATION=US

# Keep the real service-account key out of git.
CDSYNC_REAL_BQ_KEY_PATH=/absolute/path/to/service-account.json
