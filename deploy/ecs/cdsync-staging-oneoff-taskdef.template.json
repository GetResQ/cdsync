{
  "family": "cdsync-staging-oneoff",
  "taskRoleArn": "arn:aws:iam::176982589840:role/staging-task-role",
  "executionRoleArn": "arn:aws:iam::176982589840:role/staging-task-exection-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "containerDefinitions": [
    {
      "name": "cdsync",
      "image": "__IMAGE_URI__",
      "essential": true,
      "entryPoint": ["/opt/cdsync/cdsync-staging-oneoff.sh"],
      "secrets": [
        {
          "name": "CDSYNC_DB_PASSWORD",
          "valueFrom": "__DB_PASSWORD_SSM_ARN__"
        },
        {
          "name": "CDSYNC_GCP_KEY_B64",
          "valueFrom": "__GCP_KEY_B64_SSM_ARN__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/staging-resq-run-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "cdsync"
        }
      }
    }
  ]
}
